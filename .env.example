# ================================================
# Robinhood Chain (4663) Sniper - fun.noxa.fi/robinhood
# ================================================
# 
# IMPORTANT: 
# - NEVER commit this file or share real keys.
# - Use a dedicated hot wallet with small amount of ETH only.
# - Start with "dryRun": true in config.json
#
# You edit this file directly on VPS with:
#   nano .env
#
# After editing, restart with:
#   pm2 restart robinhood-sniper --update-env
#   pm2 logs robinhood-sniper

# Your wallet private key (starts with 0x)
PK=0xYOUR_PRIVATE_KEY_HERE

# Telegram Bot (optional but recommended)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (get from @userinfobot or @getmyid_bot)
TELEGRAM_CHAT_ID=

# Optional: You can override RPC here if needed
# RPC=https://rpc.mainnet.chain.robinhood.com
