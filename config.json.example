{
  "rpc": "https://rpc.mainnet.chain.robinhood.com",
  "ws": "wss://rpc.mainnet.chain.robinhood.com/ws",
  // Multiple public / free-tier RPCs for redundancy and to avoid rate limits (429/502).
  // The bot uses ethers FallbackProvider to automatically switch to a healthy one.
  // Only the official public one is truly keyless. For better reliability sign up for free keys:
  // - Alchemy: free tier at alchemy.com (create Robinhood Chain app)
  // - QuickNode, dRPC, etc. often have free credits for new users.
  "rpcs": [
    "https://rpc.mainnet.chain.robinhood.com",
    // Add your keys below for production use (uncomment and fill):
    // "https://robinhood-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE",
    // "https://YOUR_QUICKNODE_ROBINHOOD_ENDPOINT_HERE"
  ],
  "chainId": 4663,
  "factory": "0xREPLACE_WITH_ACTUAL_NOXA_FACTORY_FROM_DISCOVERY",
  "weth": "0xREPLACE_WITH_ACTUAL_WETH",
  "router": "0xREPLACE_WITH_ACTUAL_UNISWAP_V2_ROUTER",
  "snipeAmountEth": "0.0001",
  "maxConcurrentPositions": 8,
  "stopLossPct": 0.15,
  "takeProfitPct": 0.60,
  "trailingStopPct": 0.08,
  "pollIntervalMs": 2000,
  "gasMultiplier": 1.8,
  "logLevel": "info",
  "positionsFile": "positions.json",
  "eventTopic": "0x6e6ae68e7d7d45fbd855c40d1eaafa8de46c5fbec3ee26f1af88730e400bc92c",
  "honeypotCheck": true,
  "maxDailyLossPct": 5,
  "maxTradesPerHour": 20,
  "slippagePct": 10,
  "enableTelegram": true,
  "strategy": {
    "description": "Safe Meme Snipe: Tiny entries on new launches, ladder TP + trailing for profits, quick SL for capital protection, limited re-entries on dips, auto DEX exit on graduation. Moonbag: leave portion unsold for potential moonshot.",
    "tpLadder": [0.5, 1.0, 2.0],
    "tpSellPercents": [30, 30, 40],
    "reEntryOnDip": true,
    "reEntryDipPct": 0.30,
    "reEntryAmountEth": "0.00005",
    "maxReEntriesPerPosition": 2,
    "minCurveProgressForSnipe": 5,
    "maxCurveProgressForSnipe": 80,
    "moonbagPct": 25
  }
}
